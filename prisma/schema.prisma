generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  name      String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  score Int @default(0)

  puzzleStatuses TeamPuzzleStatus[]
}

model TeamPuzzleStatus {
  id String @id @default(dbgenerated("gen_random_uuid()"))

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  puzzleSlug String

  isSolved    Boolean   @default(false)
  solvedAt    DateTime?
  isHintTaken Boolean   @default(false)

  @@unique([teamId, puzzleSlug])
  @@map("team_puzzle_status")
}
