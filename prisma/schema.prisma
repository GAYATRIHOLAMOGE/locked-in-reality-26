generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GlobalState {
  id        String    @id @default("global")
  isStarted Boolean   @default(false)
  startedAt DateTime?

  // Mainframe Break Event
  isMainframeBreakActive     Boolean   @default(false)
  mainframeBreakStartedAt    DateTime?
  mainframeBreakDurationMins Int       @default(15)
  mainframeBreakCorrectValue Int       @default(14)
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  name      String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  score Int @default(0)

  hasSubmittedMainframe Boolean @default(false)

  puzzleStatuses TeamPuzzleStatus[]
}

model TeamPuzzleStatus {
  id String @id @default(dbgenerated("gen_random_uuid()"))

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  puzzleSlug String

  isSolved    Boolean   @default(false)
  solvedAt    DateTime?
  isHintTaken Boolean   @default(false)

  @@unique([teamId, puzzleSlug])
  @@map("team_puzzle_status")
}
